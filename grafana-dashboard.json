{
  "title": "GitHub Scout",
  "uid": "github-scout",
  "description": "Cross-repo GitHub work surfaced by github-scout: open pull requests, open issues, code-scanning alerts (current state), and Actions runs with a failure-rate trend (recent events). Every row links straight to GitHub. No stats for stats sake — only things that need a look.",
  "tags": ["github", "ci", "actions", "pull-requests", "issues", "security"],
  "timezone": "browser",
  "refresh": "5m",
  "schemaVersion": 42,
  "version": 2,
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "loki" },
        "hide": 2
      },
      {
        "name": "window",
        "type": "textbox",
        "label": "Snapshot window",
        "description": "How far back to read the latest snapshot of open PRs / issues / alerts. Must be >= SCAN_INTERVAL (github-scout default 15m): every open item is re-emitted each scan, and this window captures the most recent one. The time picker only affects the Actions-runs panels.",
        "query": "20m",
        "current": { "selected": true, "text": "20m", "value": "20m" },
        "options": [ { "selected": true, "text": "20m", "value": "20m" } ],
        "hide": 2,
        "skipUrlSync": false
      },
      {
        "name": "conclusion",
        "type": "custom",
        "label": "Conclusion",
        "description": "Which run conclusions the Actions runs table shows. Defaults to the failure set (failure / timed_out / startup_failure); pick All or success to see everything. Only affects the Actions runs table — the failure-rate panels always use the full set.",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "query": "failure,timed_out,startup_failure,success,cancelled,skipped,neutral,action_required",
        "current": {
          "selected": true,
          "text": ["failure", "timed_out", "startup_failure"],
          "value": ["failure", "timed_out", "startup_failure"]
        },
        "options": [
          { "selected": false, "text": "All", "value": "$__all" },
          { "selected": true, "text": "failure", "value": "failure" },
          { "selected": true, "text": "timed_out", "value": "timed_out" },
          { "selected": true, "text": "startup_failure", "value": "startup_failure" },
          { "selected": false, "text": "success", "value": "success" },
          { "selected": false, "text": "cancelled", "value": "cancelled" },
          { "selected": false, "text": "skipped", "value": "skipped" },
          { "selected": false, "text": "neutral", "value": "neutral" },
          { "selected": false, "text": "action_required", "value": "action_required" }
        ],
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "At a glance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Open PRs",
      "description": "Pull requests open across all repos right now (most recent scan). Renovate PRs are excluded by github-scout. Click into the table below to review.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 15 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(count by (repo, number) (count_over_time({container=\"github-scout\"} | json | msg=`open pull request` [$window])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 11,
      "title": "Open Issues",
      "description": "Issues open across all repos right now (most recent scan). Renovate and auto-generated trackers are excluded by github-scout.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(count by (repo, number) (count_over_time({container=\"github-scout\"} | json | msg=`open issue` [$window])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 12,
      "title": "Code Scanning Alerts",
      "description": "Open CodeQL / code-scanning alerts across all repos right now. Any open alert is worth a look; details and severity in the table below.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(count by (repo, number) (count_over_time({container=\"github-scout\"} | json | msg=`code scanning alert` [$window])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 13,
      "title": "Failed Runs (range)",
      "description": "Distinct failed / timed-out / startup-failed Actions runs in the selected time range, deduplicated by run ID and filtered from the all-runs stream by conclusion. Unlike the other tiles, this one follows the time picker.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 10 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(count by (run_id) (count_over_time({container=\"github-scout\"} | json | msg=`workflow run` | conclusion=~`failure|timed_out|startup_failure` [$__range])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 2,
      "title": "Open work \u2014 current state (most recent scan)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Open Pull Requests \u2014 click Link to review",
      "description": "Every open PR across all repos as of the most recent scan (last $window). Renovate PRs are excluded by github-scout. Use the column filters to narrow by repo or author; sorted newest first.",
      "type": "table",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Draft" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [ { "type": "value", "options": {
                "true": { "text": "draft", "color": "yellow", "index": 0 },
                "false": { "text": "ready", "color": "green", "index": 1 }
              } } ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [ { "id": "links", "value": [ { "title": "Open PR on GitHub", "url": "${__value.text}", "targetBlank": true } ] } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Created", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count by (repo, number, title, author, draft, url, created_at) (count_over_time({container=\"github-scout\"} | json | msg=`open pull request` [$window]))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "created_at", "destinationType": "time" } ] } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true },
            "indexByName": { "created_at": 0, "repo": 1, "number": 2, "title": 3, "author": 4, "draft": 5, "url": 6 },
            "renameByName": {
              "created_at": "Created", "repo": "Repo", "number": "#", "title": "Title",
              "author": "Author", "draft": "Draft", "url": "Link"
            }
          }
        }
      ]
    },
    {
      "id": 21,
      "title": "Open Issues \u2014 click Link to triage",
      "description": "Every open issue across all repos as of the most recent scan (last $window). Renovate and auto-generated (gremlins) trackers are excluded by github-scout. Sorted newest first.",
      "type": "table",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [ { "id": "links", "value": [ { "title": "Open issue on GitHub", "url": "${__value.text}", "targetBlank": true } ] } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Created", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count by (repo, number, title, author, labels, url, created_at) (count_over_time({container=\"github-scout\"} | json | msg=`open issue` [$window]))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "created_at", "destinationType": "time" } ] } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true },
            "indexByName": { "created_at": 0, "repo": 1, "number": 2, "title": 3, "author": 4, "labels": 5, "url": 6 },
            "renameByName": {
              "created_at": "Created", "repo": "Repo", "number": "#", "title": "Title",
              "author": "Author", "labels": "Labels", "url": "Link"
            }
          }
        }
      ]
    },
    {
      "id": 22,
      "title": "Code Scanning Alerts \u2014 click Link to investigate",
      "description": "Open CodeQL / code-scanning alerts across all repos as of the most recent scan (last $window). Severity is GitHub's security severity; repos without code scanning are silently skipped.",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [ { "type": "value", "options": {
                "critical": { "color": "dark-red", "index": 0 },
                "high": { "color": "red", "index": 1 },
                "medium": { "color": "orange", "index": 2 },
                "low": { "color": "yellow", "index": 3 }
              } } ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [ { "id": "links", "value": [ { "title": "Open alert on GitHub", "url": "${__value.text}", "targetBlank": true } ] } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Created", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count by (repo, number, rule, severity, tool, url, created_at) (count_over_time({container=\"github-scout\"} | json | msg=`code scanning alert` [$window]))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "created_at", "destinationType": "time" } ] } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true },
            "indexByName": { "created_at": 0, "repo": 1, "number": 2, "rule": 3, "severity": 4, "tool": 5, "url": 6 },
            "renameByName": {
              "created_at": "Created", "repo": "Repo", "number": "#", "rule": "Rule",
              "severity": "Severity", "tool": "Tool", "url": "Link"
            }
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Actions runs \u2014 selected time range",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Failure Rate (range)",
      "description": "Share of completed Actions runs that failed in the selected time range: failed / (failed + succeeded), deduplicated by run ID. Cancelled and skipped runs are excluded (not pass/fail outcomes). A rising rate means CI health is degrading. Shows \u2014 when no runs completed in range.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 33 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "noValue": "\u2014",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 30 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "(count(count by (run_id) (count_over_time({container=\"github-scout\"} | json | msg=`workflow run` | conclusion=~`failure|timed_out|startup_failure` [$__range]))) or vector(0)) / count(count by (run_id) (count_over_time({container=\"github-scout\"} | json | msg=`workflow run` | conclusion=~`failure|timed_out|startup_failure|success` [$__range]))) * 100",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 32,
      "title": "Failure rate over time",
      "description": "Percentage of completed runs that failed, bucketed over the selected range: failed / (failed + succeeded) per bucket (cancelled/skipped excluded). The trend is the signal — a sustained climb means something is breaking more often.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 33 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": true,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 30 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "(sum(count_over_time({container=\"github-scout\"} | json | msg=`workflow run` | conclusion=~`failure|timed_out|startup_failure` [$__interval])) or vector(0)) / sum(count_over_time({container=\"github-scout\"} | json | msg=`workflow run` | conclusion=~`failure|timed_out|startup_failure|success` [$__interval])) * 100",
          "legendFormat": "failure rate",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 30,
      "title": "Actions runs \u2014 click Link to investigate",
      "description": "Every completed Actions run across all repos in the selected time range, deduplicated by run ID, newest first. Filter with the Conclusion variable (top of dashboard) \u2014 it defaults to the failure set, so this opens on failed runs; switch to All or success to see everything. github-scout looks back LOOKBACK_HOURS (default 72h), so set the picker accordingly.",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 39 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Conclusion" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [ { "type": "value", "options": {
                "failure": { "color": "red", "index": 0 },
                "timed_out": { "color": "orange", "index": 1 },
                "startup_failure": { "color": "dark-red", "index": 2 },
                "success": { "color": "green", "index": 3 },
                "cancelled": { "color": "text", "index": 4 },
                "skipped": { "color": "text", "index": 5 },
                "neutral": { "color": "blue", "index": 6 },
                "action_required": { "color": "yellow", "index": 7 }
              } } ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [ { "id": "links", "value": [ { "title": "Open run on GitHub", "url": "${__value.text}", "targetBlank": true } ] } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Created", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count by (repo, workflow, conclusion, branch, event, run_number, run_id, url, created_at) (count_over_time({container=\"github-scout\"} | json | msg=`workflow run` | conclusion=~`${conclusion:pipe}` [$__range]))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "created_at", "destinationType": "time" } ] } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "run_id": true },
            "indexByName": {
              "created_at": 0, "repo": 1, "workflow": 2, "conclusion": 3,
              "branch": 4, "event": 5, "run_number": 6, "url": 7
            },
            "renameByName": {
              "created_at": "Created", "repo": "Repo", "workflow": "Workflow", "conclusion": "Conclusion",
              "branch": "Branch", "event": "Trigger", "run_number": "#", "url": "Link"
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Scout health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "id": 40,
      "title": "Scout Status",
      "description": "Whether github-scout completed a scan in the last hour. STALLED means the poller is wedged or the container is down \u2014 investigate it, because every panel above goes stale and silently reads empty.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 50 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "STALLED",
          "mappings": [
            { "type": "range", "options": { "from": 1, "to": 1000000, "result": { "text": "RUNNING", "color": "green", "index": 0 } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "STALLED", "color": "red", "index": 1 } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({container=\"github-scout\"} | json | msg=`scan complete` [1h]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 41,
      "title": "Scan Errors (last 1h)",
      "description": "github-scout's own failures (repo discovery failed \u2014 bad token, rate limit, owner typo) in the last hour. Non-zero means the scout itself is broken, not a watched repo. Tolerated per-repo warnings are not counted.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 50 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "options": {
