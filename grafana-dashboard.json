{
  "title": "GitHub Scout",
  "uid": "github-scout",
  "description": "Cross-repo GitHub work from github-scout: open pull requests, open issues, and code-scanning alerts (current state), plus recent failed Actions runs. Every row links straight to GitHub. Only what needs a look; no vanity stats.",
  "tags": ["github", "ci", "actions", "pull-requests", "issues", "security"],
  "timezone": "browser",
  "refresh": "5m",
  "schemaVersion": 42,
  "version": 5,
  "time": { "from": "now-48h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "loki" },
        "hide": 0
      },
      {
        "name": "window",
        "type": "textbox",
        "label": "Snapshot window",
        "description": "How far back to read the latest snapshot of open PRs / issues / alerts. Must be >= SCAN_INTERVAL (github-scout runs a 15m internal timer); 30m gives 2x headroom so one slow or skipped scan does not blank the snapshot. Every open item is re-emitted each scan and this window keeps only the most recent one. The time picker only affects the failed-runs panels.",
        "query": "30m",
        "current": { "selected": true, "text": "30m", "value": "30m" },
        "options": [ { "selected": true, "text": "30m", "value": "30m" } ],
        "hide": 2,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "At a glance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Open PRs",
      "description": "Pull requests open across all repos right now (most recent scan). Renovate PRs are excluded by github-scout. Click into the table below to review.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 15 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(count by (repo, number) (count_over_time({container=\"github-scout\"} | json | msg=`open pull request` [$window])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 11,
      "title": "Open Issues",
      "description": "Issues open across all repos right now (most recent scan). Renovate and auto-generated trackers are excluded by github-scout.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(count by (repo, number) (count_over_time({container=\"github-scout\"} | json | msg=`open issue` [$window])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 12,
      "title": "Code Scanning Alerts",
      "description": "Open CodeQL / code-scanning alerts across all repos right now. Any open alert is worth a look; details and severity in the table below.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(count by (repo, number) (count_over_time({container=\"github-scout\"} | json | msg=`code scanning alert` [$window])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 13,
      "title": "Failed CI runs (range)",
      "description": "Distinct failed / timed-out / startup-failed Actions runs in the selected time range, deduplicated by run ID. Unlike the other tiles, this one follows the time picker. Non-zero means CI broke somewhere; the table below has the links.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 10 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(count by (run_id) (count_over_time({container=\"github-scout\"} |= `workflow run` | json | msg=`workflow run` | conclusion=~`failure|timed_out|startup_failure` [$__range])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 2,
      "title": "Open work (act on these)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Open Pull Requests",
      "description": "Every open PR across all repos as of the most recent scan (last $window). Click the Link column to review on GitHub. Renovate PRs are excluded by github-scout. Filter by repo or author with the column headers; sorted newest first.",
      "type": "table",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Created" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-RdYlGr" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Draft" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [ { "type": "value", "options": {
                "true": { "text": "draft", "color": "yellow", "index": 0 },
                "false": { "text": "ready", "color": "green", "index": 1 }
              } } ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [ { "id": "links", "value": [ { "title": "Open PR on GitHub", "url": "${__value.text}", "targetBlank": true } ] } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Created", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count by (repo, number, title, author, draft, url, created_at) (count_over_time({container=\"github-scout\"} | json | msg=`open pull request` [$window]))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "created_at", "destinationType": "time" } ] } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true },
            "indexByName": { "created_at": 0, "repo": 1, "number": 2, "title": 3, "author": 4, "draft": 5, "url": 6 },
            "renameByName": {
              "created_at": "Created", "repo": "Repo", "number": "#", "title": "Title",
              "author": "Author", "draft": "Draft", "url": "Link"
            }
          }
        }
      ]
    },
    {
      "id": 21,
      "title": "Open Issues",
      "description": "Every open issue across all repos as of the most recent scan (last $window). Click the Link column to triage on GitHub. Renovate and auto-generated (gremlins) trackers are excluded by github-scout. Sorted newest first.",
      "type": "table",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Created" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-RdYlGr" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [ { "id": "links", "value": [ { "title": "Open issue on GitHub", "url": "${__value.text}", "targetBlank": true } ] } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Created", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count by (repo, number, title, author, labels, url, created_at) (count_over_time({container=\"github-scout\"} | json | msg=`open issue` [$window]))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "created_at", "destinationType": "time" } ] } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true },
            "indexByName": { "created_at": 0, "repo": 1, "number": 2, "title": 3, "author": 4, "labels": 5, "url": 6 },
            "renameByName": {
              "created_at": "Created", "repo": "Repo", "number": "#", "title": "Title",
              "author": "Author", "labels": "Labels", "url": "Link"
            }
          }
        }
      ]
    },
    {
      "id": 22,
      "title": "Code Scanning Alerts",
      "description": "Open CodeQL / code-scanning alerts across all repos as of the most recent scan (last $window). Click the Link column to investigate on GitHub. Severity is GitHub's security severity; repos without code scanning are silently skipped.",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Created" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-RdYlGr" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [ { "type": "value", "options": {
                "critical": { "color": "dark-red", "index": 0 },
                "high": { "color": "red", "index": 1 },
                "medium": { "color": "orange", "index": 2 },
                "low": { "color": "yellow", "index": 3 }
              } } ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [ { "id": "links", "value": [ { "title": "Open alert on GitHub", "url": "${__value.text}", "targetBlank": true } ] } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Created", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count by (repo, number, rule, severity, tool, url, created_at) (count_over_time({container=\"github-scout\"} | json | msg=`code scanning alert` [$window]))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "created_at", "destinationType": "time" } ] } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true },
            "indexByName": { "created_at": 0, "repo": 1, "number": 2, "rule": 3, "severity": 4, "tool": 5, "url": 6 },
            "renameByName": {
              "created_at": "Created", "repo": "Repo", "number": "#", "rule": "Rule",
              "severity": "Severity", "tool": "Tool", "url": "Link"
            }
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Recent CI failures",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 30,
      "title": "Failed Runs",
      "description": "Failed / timed-out / startup-failed Actions runs across all repos in the selected time range, deduplicated by run ID, newest first. Click the Link column to open the run on GitHub. Successful runs are deliberately omitted; this view is for what broke. github-scout looks back LOOKBACK_HOURS (default 72h), so set the picker within that.",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Created" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Conclusion" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [ { "type": "value", "options": {
                "failure": { "color": "red", "index": 0 },
                "timed_out": { "color": "orange", "index": 1 },
                "startup_failure": { "color": "dark-red", "index": 2 }
              } } ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Link" },
            "properties": [ { "id": "links", "value": [ { "title": "Open run on GitHub", "url": "${__value.text}", "targetBlank": true } ] } ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Created", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count by (repo, workflow, conclusion, branch, event, run_number, run_id, url, created_at) (count_over_time({container=\"github-scout\"} |= `workflow run` | json | msg=`workflow run` | conclusion=~`failure|timed_out|startup_failure` [$__range]))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        { "id": "convertFieldType", "options": { "conversions": [ { "targetField": "created_at", "destinationType": "time" } ] } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "run_id": true },
            "indexByName": {
              "created_at": 0, "repo": 1, "workflow": 2, "conclusion": 3,
              "branch": 4, "event": 5, "run_number": 6, "url": 7
            },
            "renameByName": {
              "created_at": "Created", "repo": "Repo", "workflow": "Workflow", "conclusion": "Conclusion",
              "branch": "Branch", "event": "Trigger", "run_number": "#", "url": "Link"
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Scout health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "collapsed": false
    },
    {
      "id": 40,
      "title": "Scout Status",
      "description": "Whether github-scout completed a scan in the last hour (it runs every 15m). STALLED means the scanner is wedged or the container is down; investigate it, because every panel above then goes stale and silently reads empty. github-scout's own errors (bad token, rate limit) also surface on the Live Operations error-rate panel.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 44 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "STALLED",
          "mappings": [
            { "type": "range", "options": { "from": 1, "to": 1000000, "result": { "text": "RUNNING", "color": "green", "index": 0 } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "STALLED", "color": "red", "index": 1 } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({container=\"github-scout\"} | json | msg=`scan complete` [1h]))",
          "queryType": "instant"
        }
      ]
    }
  ]
}
